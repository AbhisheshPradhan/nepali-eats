# Root .env — used by the SCRAPER + enrichment + media-sync + migration scripts
# (run from the project root, e.g. `node scraper/enrich-places.js`).
# Copy to `.env` and fill in. The Next.js app reads web/.env* instead (see
# web/.env.example). NEVER commit the real .env — only this example is tracked.

# --- Database -----------------------------------------------------------------
# Neon DIRECT (non-pooler) connection string. The scraper, reconcile, and the
# migration/upload scripts all read DATABASE_URL. The app uses the POOLED string
# (lives in web/.env*, not here).
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require&channel_binding=require
# Local fallback (pre-Neon) — uncomment to use a local Postgres instead:
# DATABASE_URL_LOCAL=postgresql://localhost:5432/nepali_eats

# --- Cloudflare R2 (media) ----------------------------------------------------
# Used by scraper/upload-media-r2.sh to sync media/ via the S3 API.
# Token = R2 -> Manage API Tokens (Object Read & Write). Server-side secrets only.
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=nepalieats-media
R2_S3_API=https://ACCOUNT_ID.r2.cloudflarestorage.com/nepalieats-media
# Public read URL (the r2.dev URL or your custom domain, NO trailing slash).
# Also becomes NEXT_PUBLIC_MEDIA_BASE in web/.env* and Vercel.
R2_PUBLIC_BASE=https://pub-XXXXXXXX.r2.dev

# --- Webshare proxies (Google scraping) ---------------------------------------
# Option A: explicit proxies, one per line or comma-separated.
#   Accepts "http://user:pass@host:port" OR Webshare's "host:port:user:pass" format.
WEBSHARE_PROXIES=host:port:user:pass,host:port:user:pass
# Option B: Webshare "Proxy List -> Download" URL (returns host:port:user:pass lines).
# WEBSHARE_LIST_URL=https://proxy.webshare.io/api/v2/proxy/list/download/...

# --- Google Places API (New) --------------------------------------------------
# Place Details pass (enrich-places.js). Restrict the key to Places API in GCP.
GOOGLE_PLACES_API_KEY=your_google_places_api_key
