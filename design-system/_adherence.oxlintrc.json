{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/listings/**",
              "ui_kits/web/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Baloo 2|Mukta))/i]",
        "message": "Font not provided by the design system. Available: Baloo 2, Mukta."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|ring|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, ring, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|solid|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, solid, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|open|closed|favourite|info)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'open' | 'closed' | 'favourite' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|pill|block|disabled|iconLeft|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, pill, block, disabled, iconLeft, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:iconLeft|size|style|wrapStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: iconLeft, size, style, wrapStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlaceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|image|venueType|cuisines|rating|reviewCount|suburb|distance|priceLevel|isOpen|hoursLine|favourite|onClick|style|key|ref|className|style|children)$/]",
        "message": "<PlaceCard> doesn't accept that prop. Declared props: name, image, venueType, cuisines, rating, reviewCount, suburb, distance, priceLevel, isOpen, hoursLine, favourite, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlaceCard'] > JSXAttribute[name.name='venueType'] > Literal[value!=/^(?:Restaurant|Cafe|Food truck|Stall)$/]",
        "message": "<PlaceCard> venueType must be one of 'Restaurant' | 'Cafe' | 'Food truck' | 'Stall'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Rating'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|count|size|showValue|style|key|ref|className|style|children)$/]",
        "message": "<Rating> doesn't accept that prop. Declared props: value, max, count, size, showValue, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|clickable|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: active, clickable, children."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
