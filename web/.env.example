# web/.env — used by the Next.js APP (dev + Vercel).
# Copy to web/.env (and/or web/.env.local) and fill in. Set the same vars in the
# Vercel project settings for prod. NEVER commit the real env files.
#
# NOTE: NEXT_PUBLIC_* vars are inlined at BUILD time and exposed to the browser —
# only put non-secret values there. Everything else is server-only.

# --- Database -----------------------------------------------------------------
# Neon POOLED (serverless-safe) connection string for the app.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.neon.tech/neondb?sslmode=require
# Local fallback (pre-Neon) — uncomment to use a local Postgres instead:
# DATABASE_URL_LOCAL=postgresql://localhost:5432/nepali_eats

# --- Site URL (SEO) -----------------------------------------------------------
# Absolute base for sitemap, robots, all canonical tags, OG images, and JSON-LD
# @id/url. Set to the LIVE origin (no trailing slash). On Vercel set this to the
# real deployment/custom domain — do NOT leave a placeholder, it gets emitted
# literally. If unset, the code falls back to https://nepalieats.com.au.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Mapbox -------------------------------------------------------------------
# Public token — enables the real map (Explore / MapPreview). Restart dev after changing.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token

# --- Clerk (auth / admin) -----------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
# Comma-separated Clerk user ids allowed into /admin (and /api/admin).
# Sign in once via the header, copy your user id from the Clerk dashboard, paste here.
ADMIN_USER_IDS=user_xxx,user_yyy
# Clerk webhook signing secret (Dashboard -> Webhooks -> your endpoint).
# Needed for /api/webhooks/clerk to verify signatures.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_signing_secret

# --- Cloudflare R2 (media) ----------------------------------------------------
# Public read URL for next/image + mediaUrl(). Safe to expose (it's public).
NEXT_PUBLIC_MEDIA_BASE=https://pub-XXXXXXXX.r2.dev
# Server-side ONLY (admin upload routes -> R2 S3 API). NOT NEXT_PUBLIC.
R2_S3_API=https://ACCOUNT_ID.r2.cloudflarestorage.com/nepalieats-media
R2_BUCKET=nepalieats-media
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
